                                waitR(2, 2)
                                break
                            end
                        end
                    end
                end
            end
        end

        waitR(5, 7)

        local tradeButton = nil
        for _, btn in pairs(tradeWindow:GetDescendants()) do
            if btn.Name == "ReadyButton" and btn:IsA("ImageButton") then
                tradeButton = btn
                break
            end
        end

        if tradeButton then
            for _, c in pairs(getconnections(tradeButton.Activated)) do c:Fire() end
            task.wait(2)
            for i = 1, 30 do
                for _, c in pairs(getconnections(tradeButton.Activated)) do c:Fire() end
                task.wait(2)
            end
        end
    end
