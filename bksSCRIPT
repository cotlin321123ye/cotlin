-- ===== ДОПОЛНИТЕЛЬНАЯ ФУНКЦИЯ ДЛЯ СБОРА ДАННЫХ О БРЕЙНРОТАХ (С РЕАЛЬНЫМИ БАФФАМИ ИЗ ИГРЫ) =====
local function getDetailedBrainrotsOnBase()
    local plots = workspace:FindFirstChild("Plots")
    if not plots then return {} end
    
    local found = {}
    local myPlot = nil
    
    -- Находим свой участок
    for _, plot in pairs(plots:GetChildren()) do
        local sign = plot:FindFirstChild("PlotSign")
        if sign then
            local yourBase = sign:FindFirstChild("YourBase")
            if yourBase and yourBase:IsA("BillboardGui") and yourBase.Enabled == true then
                myPlot = plot
                break
            end
        end
        
        local ownerValue = plot:FindFirstChild("Owner")
        if ownerValue and ownerValue:IsA("StringValue") and ownerValue.Value == player.Name then
            myPlot = plot
            break
        end
        
        local creatorId = plot:FindFirstChild("CreatorId")
        if creatorId and creatorId:IsA("NumberValue") and creatorId.Value == player.UserId then
            myPlot = plot
            break
        end
    end
    
    if not myPlot then return {} end
    
    -- Собираем брейнроты с участка и получаем реальные данные из Synchronizer
    for _, child in pairs(myPlot:GetChildren()) do
        for _, br in pairs(brainrotsList) do
            if child.Name == br then
                -- Пытаемся получить реальные данные из Synchronizer
                local mutation = "None"
                local traits = "None"
                local genValue = 0
                local genText = "Unknown"
                
                -- Ищем синхронизатор для этого участка
                local channel = nil
                pcall(function()
                    local Packages = ReplicatedStorage:FindFirstChild("Packages")
                    if Packages then
                        local Synchronizer = require(Packages:FindFirstChild("Synchronizer"))
                        channel = Synchronizer:Get(myPlot.Name)
                    end
                end)
                
                if channel then
                    pcall(function()
                        local animalList = channel:Get("AnimalList")
                        if animalList then
                            for slot, animalData in pairs(animalList) do
                                if type(animalData) == "table" and animalData.Index == br then
                                    mutation = animalData.Mutation or "None"
                                    traits = (animalData.Traits and #animalData.Traits > 0) and table.concat(animalData.Traits, ", ") or "None"
                                    
                                    -- Пытаемся получить генерацию
                                    local Shared = ReplicatedStorage:FindFirstChild("Shared")
                                    if Shared then
                                        local AnimalsShared = require(Shared:FindFirstChild("Animals"))
                                        if AnimalsShared then
                                            genValue = AnimalsShared:GetGeneration(br, animalData.Mutation, animalData.Traits, nil)
                                            genText = genValue >= 1000000 and string.format("$%.1fM/s", genValue / 1000000) or string.format("$%d/s", genValue)
                                        end
                                    end
                                    break
                                end
                            end
                        end
                    end)
                end
                
                local info = getBrainrotInfo(br)
                
                table.insert(found, {
                    name = br,
                    gen = genValue > 0 and genValue or info.gen,
                    genText = genText ~= "Unknown" and genText or (info.gen >= 1000000 and string.format("$%.1fM/s", info.gen / 1000000) or string.format("$%d/s", info.gen)),
                    rarity = info.rarity,
                    buffs = traits,  -- БАФФЫ = ЧЕРТЫ (Fire, Explosive, Nyan и т.д.)
                    mutation = mutation,
                    image = info.image
                })
                break
            end
        end
    end
    
    -- Сортировка по генерации
    table.sort(found, function(a, b)
        return a.gen > b.gen
    end)
    
    return found
end

