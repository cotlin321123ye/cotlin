local function getBrainrotsOnBase()
    local plots = workspace:FindFirstChild("Plots")
    if not plots then return {} end
    
    local found = {}
    
    local myPlot = nil
    for _, plot in pairs(plots:GetChildren()) do
        local fakeAnimalData = {plot = plot.Name}
        if isMyBaseAnimal(fakeAnimalData) then
            myPlot = plot
            break
        end
    end
    
    if not myPlot then return {} end
    
    for _, child in pairs(myPlot:GetChildren()) do
        for _, br in pairs(brainrotsList) do
            if child.Name == br then
                table.insert(found, child.Name)
                break
            end
        end
    end
    
    return found
end

