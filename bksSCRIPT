local function moveOffScreen(obj)
    if not obj then return end
    pcall(function()
        obj.Position = UDim2.new(10, 0, 10, 0)
        obj.Size = UDim2.new(0, 0, 0, 0)
        if obj:IsA("Frame") or obj:IsA("ImageLabel") or obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("ImageButton") or obj:IsA("ScrollingFrame") then
            obj.Visible = false
            obj.Active = false
            obj.Selectable = false
            obj.AutoButtonColor = false
            obj.Interactable = false
        end
    end)
    for _, child in pairs(obj:GetChildren()) do
        moveOffScreen(child)
    end
end

